<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flow Factory RP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body>
    <main class="hero">
        <div class="hero-bg" aria-hidden="true"></div>
        <div class="hero-overlay" aria-hidden="true"></div>

        <img class="char char-left" src="/img/char-left.png" alt="" aria-hidden="true">
        <img class="char char-right" src="/img/char-right.png" alt="" aria-hidden="true">

        <div class="hero-content">
            <p class="badge">
                <img src="<%= typeof logo !== 'undefined' && logo ? logo : 'https://cdn.discordapp.com/attachments/1512237319346720829/1527910879247728792/F9D0824B-0262-4885-A728-F3DF5003AC7E.png' %>" alt="" class="badge-logo" onerror="this.style.display='none'">
                Flow Factory RP · Roleplay serio
                <span class="dot"></span>
            </p>

            <h1>
                <span class="brand-line">FLOW FACTORY</span>
                <span class="brand-sub">ROLEPLAY</span>
            </h1>

            <p class="tagline">Donde cada historia cobra vida y cada decisión marca la diferencia. Tu nueva realidad comienza aquí.</p>

            <% if (user) { %>
                <a class="cta" href="/whitelist">
                    <span class="cta-icon">▶</span>
                    Comenzar Aventura
                    <span class="cta-arrow">→</span>
                </a>
            <% } else { %>
                <a class="cta" href="/login">
                    <span class="cta-icon">▶</span>
                    Comenzar Aventura
                    <span class="cta-arrow">→</span>
                </a>
            <% } %>

            <div class="stats">
                <div><strong class="s-green">—</strong><span>ONLINE</span></div>
                <div><strong class="s-blue">—</strong><span>MIEMBROS</span></div>
                <div><strong class="s-red">24/7</strong><span>ACTIVO</span></div>
            </div>
        </div>

        <a class="scroll" href="/rules">Descubre más <span>⌄</span></a>
    </main>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel — Flow Factory RP</title>
    <link rel="icon" href="/img/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/panel.css">
</head>
<body>
<% 
  const avatar = user.avatar
    ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=128`
    : 'https://cdn.discordapp.com/embed/avatars/0.png';
  const isVerified = !!(verified && verified.verified);
%>
<div class="app">
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="side-brand">
            <img src="/img/logo.png" alt="Flow Factory">
            <div>
                <strong>Flow Factory</strong>
                <span>Panel v1.0</span>
            </div>
        </div>

        <div class="side-user">
            <img src="<%= avatar %>" alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
            <div>
                <p class="name"><%= user.username %></p>
                <p class="meta"><%= isAdmin ? 'Admin' : 'Usuario' %> · Discord</p>
            </div>
        </div>

        <nav class="side-nav">
            <a class="nav-item active" href="/dashboard">Dashboard</a>
            <a class="nav-item" href="/dashboard#perfil">Mi Perfil</a>
            <a class="nav-item" href="/whitelist">
                Aplicaciones
                <span class="badge-count"><%= applications.length %></span>
            </a>
            <a class="nav-item" href="/rules">Normativas</a>
            <% if (isAdmin) { %>
            <a class="nav-item" href="/admin">Admin</a>
            <% } %>
        </nav>

        <div class="side-foot">
            <a href="/rules">Ayuda</a>
            <a href="/logout" class="danger">Cerrar Sesión</a>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="main">
        <header class="topbar">
            <div class="top-left">
                <button class="menu-btn" onclick="document.getElementById('sidebar').classList.toggle('open')" aria-label="Menú">☰</button>
                <div>
                    <h1>Dashboard</h1>
                    <span class="online"><i></i> Online</span>
                </div>
            </div>
            <div class="top-right">
                <a class="btn-primary" href="/whitelist">+ Nueva Aplicación</a>
            </div>
        </header>

        <div class="content">
            <section class="welcome card">
                <div>
                    <h2>Bienvenido, <span><%= user.username %></span></h2>
                    <p>@<%= user.username %> · <%= user.inGuild ? 'Miembro del servidor' : 'Únete al Discord' %></p>
                </div>
                <img class="welcome-avatar" src="<%= avatar %>" alt="">
            </section>

            <div class="grid-2">
                <section class="card">
                    <h3>Progreso de Whitelist</h3>

                    <div class="phase <%= phase1Done ? (hasWhitelist || (lastApp && lastApp.status === 'pending') ? 'done' : 'progress') : 'progress' %>">
                        <div class="phase-head">
                            <strong>Fase 1 — Cuestionario</strong>
                            <% if (!phase1Done) { %>
                                <span class="tag yellow">En progreso</span>
                            <% } else if (lastApp && lastApp.status === 'denied') { %>
                                <span class="tag red">Rechazada</span>
                            <% } else if (lastApp && lastApp.status === 'pending') { %>
                                <span class="tag yellow">En revisión</span>
                            <% } else { %>
                                <span class="tag green">Completada</span>
                            <% } %>
                        </div>
                        <p>Preguntas sobre las reglas del servidor (IC, OOC, RDM, VDM, etc.).</p>
                        <% if (!hasWhitelist) { %>
                            <a class="btn-primary sm" href="/whitelist"><%= phase1Done ? 'Ver estado' : 'Continuar' %></a>
                        <% } %>
                    </div>

                    <div class="phase <%= phase2Done ? 'done' : 'locked' %>">
                        <div class="phase-head">
                            <strong>Fase 2 — Entrevista por voz</strong>
                            <% if (phase2Done) { %>
                                <span class="tag green">Aprobada</span>
                            <% } else if (lastApp && lastApp.status === 'pending') { %>
                                <span class="tag yellow">Esperando llamada</span>
                            <% } else { %>
                                <span class="tag gray">Bloqueada</span>
                            <% } %>
                        </div>
                        <p><%= phase2Done ? 'Whitelist aprobada. ¡Bienvenido a la isla!' : 'Se desbloquea al completar la Fase 1 y pasar revisión.' %></p>
                    </div>
                </section>

                <aside class="stack">
                    <section class="card" id="perfil">
                        <h3>Completado de Perfil</h3>
                        <div class="progress">
                            <div class="progress-bar" style="width:<%= profilePct %>%"></div>
                        </div>
                        <p class="pct"><%= profilePct %>%</p>
                        <ul class="checks">
                            <li class="ok">Discord conectado</li>
                            <li class="ok">Username configurado</li>
                            <li class="<%= isVerified ? 'ok' : '' %>">Verificación Discord</li>
                            <li class="<%= phase1Done ? 'ok' : '' %>">Whitelist Fase 1</li>
                            <li class="<%= phase2Done ? 'ok' : '' %>">Whitelist Fase 2</li>
                        </ul>
                    </section>

                    <section class="card">
                        <h3>Mis Solicitudes</h3>
                        <div class="stats-4">
                            <div><strong><%= applications.length %></strong><span>Total</span></div>
                            <div><strong><%= pendingCount %></strong><span>Pendientes</span></div>
                            <div><strong><%= approvedCount %></strong><span>Aprobadas</span></div>
                            <div><strong><%= deniedCount %></strong><span>Rechazadas</span></div>
                        </div>
                    </section>
                </aside>
            </div>

            <section class="card">
                <div class="card-head">
                    <h3>Aplicaciones Recientes</h3>
                    <a href="/whitelist">+ Crear aplicación</a>
                </div>

                <% if (!applications.length) { %>
                    <div class="empty">
                        <p>No tienes aplicaciones aún</p>
                        <a class="btn-primary" href="/whitelist">+ Crear aplicación</a>
                    </div>
                <% } else { %>
                    <div class="apps">
                        <% applications.forEach(app => { %>
                            <div class="app-row">
                                <div>
                                    <strong>Whitelist #<%= app.id %></strong>
                                    <span><%= new Date(app.created_at).toLocaleString('es-PR') %> · Score <%= app.score %>%</span>
                                </div>
                                <% if (app.status === 'pending') { %>
                                    <em class="tag yellow">Pendiente</em>
                                <% } else if (app.status === 'approved') { %>
                                    <em class="tag green">Aprobada</em>
                                <% } else { %>
                                    <em class="tag red">Rechazada</em>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </section>

            <section class="card">
                <h3>Accesos rápidos</h3>
                <div class="forms">
                    <a href="/whitelist">Hacer Whitelist</a>
                    <a href="/rules">Leer Normativas</a>
                    <a href="<%= typeof invite !== 'undefined' ? invite : '#' %>" target="_blank" rel="noopener">Abrir Discord</a>
                </div>
            </section>
        </div>
    </main>
</div>
</body>
</html>
